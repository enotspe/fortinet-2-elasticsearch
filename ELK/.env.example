# Elasticsearch connection
ES_URL=https://localhost:9200

# Authentication: "user" or "apikey"
AUTH_METHOD=user

# User/password auth
ES_USERNAME=elastic
ES_PASSWORD=changeme

# API key auth (use instead of user/password when AUTH_METHOD=apikey)
#ES_API_KEY=

# Skip SSL certificate validation (set to true for self-signed certs)
INSECURE=false

# What to load
LOAD_ECS=true
LOAD_COMPONENT=true
LOAD_ILM=true
LOAD_INDEX_TEMPLATES=true
LOAD_INGEST_PIPELINES=false
LOAD_TRANSFORMS=false

# ECS version (leave empty for latest)
#ECS_VERSION=8.11.0
USE_EXISTING_ECS=true

# Behaviour
CONTINUE_ON_ERROR=true
VERBOSE=false
